{
  "name": "filepro",
  "version": "1.0.0",
  "description": "FilePro 全能格式转换器",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev": "npm run build:main && electron .",
    "package": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.filepro.converter",
    "productName": "FilePro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": false,
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FilePro 全能转换器"
    },
    "portable": {
      "artifactName": "FilePro_Portable.exe"
    }
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "lucide-react": "^0.344.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.9.3"
  }
}
